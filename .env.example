# Database — Settings → Database → Connection pooling → URI
SUPABASE_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Auth — Settings → API (backend only)
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public URLs — must mirror frontend env vars
# BE_URL  = VITE_BE_URL on frontend
# FE_URL  = VITE_FE_URL on frontend (comma-separated for multiple origins)
BE_URL=http://localhost:3001
FE_URL=http://localhost:5173

# Production (Vercel):
# BE_URL=https://toolhub-be.vercel.app
# FE_URL=https://toolhub-fe.vercel.app

# Seed (optional)
SEED_ADMIN_EMAIL=admin@toolvault.io
SEED_ADMIN_PASSWORD=Admin123!

# Auth session: set Supabase refresh token expiry to 604800 (7 days) in dashboard.
# See SETUP.md → Auth session (7 days)
